#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Running pre-push checks..."

cd frontend || exit 1
npm run lint:eslint:ci || exit 1
npm run format:check || exit 1
cd - >/dev/null || exit 1

cd backend || exit 1
npm run lint || exit 1
cd - >/dev/null || exit 1

echo "Pre-push checks passed."
